# 律师智能体环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ========== RAG配置 ==========
# 阿里云RAG库API端点
RAG_API_ENDPOINT=http://localhost:8000
# 阿里云RAG库API密钥
RAG_API_KEY=your_rag_api_key_here

# ========== 联网研究配置 ==========
# 关闭时不调用 Tavily/Brave；开启后仍保持本地 RAG 优先。
ENABLE_EXTERNAL_SEARCH=false
TAVILY_API_KEY=tvly-your_api_key_here
TAVILY_PROJECT_ID=
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here
WEB_SEARCH_TIMEOUT=20
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_MAX_TOKENS=8192

# ========== LLM配置 ==========
# LLM提供商：openai-compatible / openai / custom
LLM_PROVIDER=openai-compatible
# 旧的 LLM_API_KEY / LLM_API_ENDPOINT / LLM_MODEL 调用方式已冻结，当前模型调用只读取 MINIMAX_*。
# MiniMax API端点
MINIMAX_API_ENDPOINT=https://api.minimaxi.com/v1
# MiniMax API密钥：只从本地环境变量读取，不写入代码
MINIMAX_API_KEY=your_minimax_api_key_here
# MiniMax模型名称
MINIMAX_MODEL=MiniMax-M2.7
# 逗号分隔的回退模型，主模型报错或空响应时依次尝试
MINIMAX_FALLBACK_MODELS=
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=200000
LLM_TIMEOUT=60

# ========== 应用配置 ==========
# 环境：development / production
ENVIRONMENT=development

# ========== 飞书配置 ==========
# 飞书机器人的App ID
FEISHU_APP_ID=your_feishu_app_id
# 飞书机器人的App Secret
FEISHU_APP_SECRET=your_feishu_app_secret
# 飞书机器人Token
FEISHU_BOT_TOKEN=your_feishu_bot_token

# ========== OpenClaw配置 ==========
# OpenClaw服务地址
OPENCLAW_ENDPOINT=http://localhost:8080
# OpenClaw认证Token
OPENCLAW_TOKEN=your_openclaw_token
